{
    "useTabs": true,
    "tabWidth": 2,
    "endOfLine": "lf",
    "trailingComma": "none",
    "semi": true,
    "singleQuote": true,
    "plugins": [
        "prettier-plugin-tailwindcss",
        "prettier-plugin-go-template"
    ],
    "overrides": [
        {
            "files": ["*.html"],
            "options": {
            "parser": "go-template"
            }
        }
    ]
}