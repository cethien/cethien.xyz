    "version": "0.2.0",
    "configurations": [
        {
            "name": "launch dev server",
            "type": "node-terminal",
            "request": "launch",
            "command": "./node_modules/.bin/astro dev"
        },
        {
            "name": "explore @ localhost",
            "type": "firefox",
            "request": "launch",
            "url": "http://localhost:3000/",
            "reAttach": true,
        }
    ],
    "compounds": [
        {
            "name": "DEV",
            "configurations": [
                "launch dev server",
                "explore @ localhost"
            ],
            "stopAll": true
        }
    ]
}