{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "launch web dev server",
            "type": "node-terminal",
            "request": "launch",
            "command": "./node_modules/.bin/turbo dev --filter=web"
        },
        {
            "name": "explore web @ localhost",
            "type": "firefox",
            "request": "launch",
            "url": "http://localhost:3000/",
            "reAttach": true,
        }
    ],
    "compounds": [
        {
            "name": "DEV:web",
            "configurations": [
                "launch web dev server",
                "explore web @ localhost"
            ],
            "stopAll": true
        }
    ]
}